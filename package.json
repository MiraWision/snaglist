{
  "name": "sluglist",
  "version": "1.1.1",
  "description": "Universal embeddable feedback widget: capture visual feedback (element, area, full page) on dev and staging sites, annotate it, and deliver artifacts through pluggable connectors.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/sluglist.global.js",
  "jsdelivr": "./dist/sluglist.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "npm pack",
    "prepublishOnly": "npm run build",
    "publish": "npm publish --access public"
  },
  "keywords": [
    "feedback",
    "widget",
    "bug report",
    "screenshot",
    "annotation",
    "html-to-image",
    "visual feedback",
    "qa",
    "staging",
    "typescript",
    "sluglist"
  ],
  "author": "Yelysei Lukin <yelysei277@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/MiraWision/sluglist.git"
  },
  "bugs": {
    "url": "https://github.com/MiraWision/sluglist/issues"
  },
  "homepage": "https://mirawision.github.io/sluglist",
  "license": "MIT",
  "dependencies": {
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "yaml": "^2.8.0"
  }
}
